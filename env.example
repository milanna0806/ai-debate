# ALPHA и BETA говорят через OpenRouter (один ключ на оба бота,
# бесплатные модели, без карты)
OPENROUTER_API_KEY=sk-or-v1-...

# Арбитр выносит вердикт через Claude (Anthropic) — нейтральная третья модель,
# скорее всего у тебя этот ключ уже стоит в Vercel с первого деплоя
ANTHROPIC_API_KEY=sk-ant-...
